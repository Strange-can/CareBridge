---
layout: base.njk
css:
  - '/css/requests.css'
---
<section id="cont" class="container-fluid">
  <aside class="container" id="cont-aside">
        
    <button class="arrow-btn" id="arrow-btn-left" onclick="
        addClass('#cont-aside', 'hide-aside');
        addClass('#right', 'full-section');
        remClass('#arrow-btn-right', 'hide-arrow');
        addClass(this, 'hide-arrow')">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><rect fill="none"/><rect x="40" y="40" width="176" height="176" rx="8" transform="translate(256 0) rotate(90)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="88" y1="128" x2="168" y2="128" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><polyline points="120 96 88 128 120 160" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
    </button>
    
    
    <button class="arrow-btn hide-arrow" id="arrow-btn-right" onclick="remClass('#cont-aside', 'hide-aside'); remClass('#right', 'full-section'); remClass('#arrow-btn-left', 'hide-arrow'); addClass(this, 'hide-arrow')" >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><rect fill="none"/><rect x="40" y="40" width="176" height="176" rx="8" transform="translate(256) rotate(90)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="88" y1="128" x2="168" y2="128" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><polyline points="136 96 168 128 136 160" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
    </button>
    
    <form>
      <h2 style="padding-top: 11px;">Filter Requests</h2>
      <hr />
      <div class="grid">
        <select name="type" aria-label="type" required>
          <option selected value="all">Type (All)</option>
          <option value="hospitals">Hospitals</option>
          <option value="individuals">Individuals</option>
        </select>
        <select name="priority" aria-label="priority" required>
          <option selected value="all">Priority (All)</option>
          <option value="life">Life</option>
          <option value="normal">Normal</option>
        </select>
      </div>
      
      <div>
        <select name="amount" aria-label="amount" required>
          <option selected value="newest">Newest first</option>
          <option value="lowest">Lowest first $</option>
          <option value="highest">Highest first $$$</option>
        </select>
      </div>
      
      <input type="submit" value="Filter" />
    </form>
  </aside>
  <section id="right">
    <article>
      <header>
        <div class="inner-1">
          <div class="hospital-logo"></div>
          <span>North Hospital LTD.</span>
        </div>
        
        <div role="button" class="outline secondary">Hospital</div>
      </header>
      
      <span>Medicines:</span>
      
      <ul>
        <li>bla bla - Quantity = 2</li>
        <li>bla bla 2 - Quantity = 5</li>
      </ul>
      
      <span>Costs:</span>
      <ul>
        <li>Bill Cost = $80</li>
        <li>Medicine Cost = $70</li>
      </ul>
      
      <p>Patient ID: 457878964421</p>
      <p>Request Date: Thu Apr 30 2026 12:55:56 GMT+0300</p>
      
      <div class="tags">
        <span class="priority" style="background-color: darkblue;">Normal</span>
        <span class="donation-amount">$150</span>
      </div>
      
      <footer class="grid">
        <a role="button" style="font-weight: bold;" href="/requests">DONATE <img src='/icons/tip-jar.svg' /></a>
        <a role="button" style="font-weight: bold;" class="secondary" href="/requests/contact">CONTACT <img src='/icons/chat-centered-dots.svg' /></a>
      </footer>
    </article>
    
    <article>
      <header>
        <div class="inner-1">
          [INDIVIDUAL_RANDOM__ANYNOMOUS_ID_GOES_HERE]
        </div>
        
        <div role="button" class="outline secondary">Individual</div>
      </header>
      
      <span>Medicines:</span>
      
      <ul>
        <li>bla bla - Quantity = 7</li>
        <li>bla bla 2 - Quantity = 4</li>
      </ul>
      
      <div class="tags">
        <span class="priority" style="background-color: #E63946;">Life</span>
        <span class="donation-amount">$120</span>
      </div>
      
      <footer class="grid">
        <a role="button" style="font-weight: bold;" href="/requests">DONATE <img src='/icons/tip-jar.svg' /></a>
        <a role="button" style="font-weight: bold;" class="secondary" href="/requests/contact">TELEGRAM <img src='/icons/telegram-logo.svg' /></a>
      </footer>
    </article>
  </section>
</section>
  
