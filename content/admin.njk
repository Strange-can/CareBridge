<h1>Pending Hospital Approvals 📋</h1>
<div id="pending-hospitals"></div>

<script type="module">
  import { collection, query, where, getDocs, doc, updateDoc } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";

  const container = document.getElementById('pending-hospitals');

  async function getPendings() {
    const q = query(collection(window.db, "users"), 
              where("role", "==", "hospital"), 
              where("isApproved", "==", false));
    
    const snap = await getDocs(q);
    
    if(snap.empty) {
        container.innerHTML = "<p>No pending applications. Coffee time! ☕</p>";
        return;
    }

    snap.forEach((hospital) => {
      const h = hospital.data();
      const card = document.createElement('article');
      card.innerHTML = `
        <h3>${h.name}</h3>
        <p><strong>Location:</strong> ${h.city}, ${h.country}</p>
        <p><strong>Reason:</strong> ${h.answers[0]}</p>
        <a href="${h.location}" target="_blank">View on Maps 📍</a>
        <hr>
        <button onclick="approve('${hospital.id}')">Approve Hospital ✅</button>
      `;
      container.appendChild(card);
    });
  }

  window.approve = async (id) => {
    await updateDoc(doc(window.db, "users", id), { isApproved: true });
    alert("Approved!");
    location.reload();
  };

  getPendings();
</script>
