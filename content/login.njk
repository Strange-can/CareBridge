---
layout: base.njk
css:
  - '/css/auth-forms.css'
js:
  - '/js/login-user.js'
---

<div>
    <h1>Welcome Back!</h1>

    <section>
        <form id="loginForm">
            <label>
                Email
                <input type="email" id="email" required />
            </label>

            <label>
                Password
                <input type="password" id="password" required />
            </label>
            
            <button type="submit">
                Login
            </button>
        </form>
        <a href="/contact">Forgot your password?</a>
        <br />
        
        <p id="message"></p>
        <a href="/signup">Don't have an account? Register now for free!</a>
    </section>
</div>

