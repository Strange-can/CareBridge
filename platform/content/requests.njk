---
layout: base.njk
css:
  - '/css/requests.css'
---
<section id="cont" class="container-fluid">
  <aside class="container" id="cont-aside">
    <form role="search">
      <input name="search" type="search" placeholder="Search for hospital.." />
      <input type="submit" value="Search" />
    </form>
    
    
    <button class="arrow-btn" id="arrow-btn-left" onclick="
        addClass('#cont-aside', 'hide-aside');
        addClass('#right', 'full-section');
        remClass('#arrow-btn-right', 'hide-arrow');
        addClass(this, 'hide-arrow')">
        <img src='/icons/arrow-square-left.svg' />
    </button>
    
    
    <button class="arrow-btn hide-arrow" id="arrow-btn-right" onclick="remClass('#cont-aside', 'hide-aside'); remClass('#right', 'full-section'); remClass('#arrow-btn-left', 'hide-arrow'); addClass(this, 'hide-arrow')" >
      <img src='/icons/arrow-square-right.svg' />
    </button>
    
    <form>
      <h2>Filter Requests</h2>
      <hr />
      <div class="grid">
        <select name="type" aria-label="type" required>
          <option selected value="all">Type (All)</option>
          <option value="hospitals">Hospitals</option>
          <option value="individuals">Individuals</option>
        </select>
        <select name="priority" aria-label="priority" required>
          <option selected value="all">Priority (All)</option>
          <option value="life">Life</option>
          <option value="normal">Normal</option>
        </select>
      </div>
      
      <div>
        <select name="amount" aria-label="amount" required>
          <option selected value="newest">Newest first</option>
          <option value="lowest">Lowest first $</option>
          <option value="highest">Highest first $$$</option>
        </select>
      </div>
      
      <input type="submit" value="Filter" />
    </form>
  </aside>
  <section id="right">
    <article>
      <header>
        <div class="inner-1">
          <div class="hospital-logo"></div>
          <span>North Hospital LTD.</span>
        </div>
        
        <div role="link" class="trust">Trusted <img src='/icons/shield-check.svg' /></div>
      </header>
      
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris vol..</p>
      
      <div class="tags">
        <span class="priority">VERY HIGH</span>
        <span class="donation-amount">$0 of $50k needed</span>
      </div>
      
      <footer class="grid">
        <a role="button" style="font-weight: bold;" href="/requests">DONATE <img src='/icons/tip-jar.svg' /></a>
        <a role="button" style="font-weight: bold;" class="secondary" href="/requests/contact">CONTACT <img src='/icons/chat-centered-dots.svg' /></a>
      </footer>
    </article>
    
    <article>
      <header>
        <div class="inner-1">
          <div class="hospital-logo"></div>
          <span>North Hospital LTD.</span>
        </div>
        
        <div role="link" class="trust">Trusted <img src='/icons/shield-check.svg' /></div>
      </header>
      
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris vol..</p>
      
      <div class="tags">
        <span class="priority">VERY HIGH</span>
        <span class="donation-amount">$0 of $50k needed</span>
      </div>
      
      <footer class="grid">
        <a role="button" style="font-weight: bold;" href="/requests">DONATE <img src='/icons/tip-jar.svg' /></a>
        <a role="button" style="font-weight: bold;" class="secondary" href="/requests/contact">CONTACT <img src='/icons/shield-check.svg' /></a>
      </footer>
    </article>
  </section>
</section>
  
