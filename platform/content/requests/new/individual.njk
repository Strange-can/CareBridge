---
layout: base.html
title: Medical Request Form
style:'
  :root {
      --primary: #2563eb;
    }
'
---

<section class="container">
<h2> Medical Assistance Request</h2>

  <form>
    <label>
      Medicine Name
      <input type="text" required>
    </label>

    <label>
      Cost (₹)
      <input type="number" required>
    </label>

    <label>
      City
      <input type="text" required>
    </label>

    <label>
  Pharmacy Name
  <input type="text" placeholder="Enter pharmacy name">
    </label>

    <label>
  Google Maps Link (Pharmacy)
  <input type="url" placeholder="Paste Google Maps link">
    </label>

    <label>
  Contact (WhatsApp/Telegram)
  <input type="text" placeholder="Enter contact info">
    </label>
   
    <label>
      Upload Bill
      <input type="file">
    </label>

 <fieldset>
  <label>
    <input type="checkbox" name="urgent">
    Mark as urgent
  </label>

  <label>
    <input type="checkbox" required>
    I confirm all details are correct and valid
  </label>
</fieldset>

    <button type="submit">Submit Request</button>
  </form>
</section>
